PORT=3001

# Turso (libSQL) — required in production, optional locally (falls back to file:./data/local.db)
# Create a free database at https://turso.tech and paste the credentials below.
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Required for AI fallback in POST /api/recipes/import (Tier 3 extraction).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
